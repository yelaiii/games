{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["oxc", "typescript", "unicorn", "import", "react"],
  "jsPlugins": ["@unocss/eslint-plugin"],
  "categories": { "perf": "error", "correctness": "error" },
  "rules": {
    "@unocss/order": ["error", { "unoFunctions": ["cva", "cn"], "unoVariables": ["className"] }],

    "eslint/no-useless-assignment": "error",
    "eslint/array-callback-return": "error",
    "eslint/max-classes-per-file": "error",
    "eslint/eqeqeq": "error",
    "eslint/no-useless-return": "error",
    "eslint/yoda": "error",
    "eslint/arrow-body-style": ["error", "as-needed"],
    "eslint/curly": ["error", "multi-line"],
    "eslint/no-nested-ternary": "error",
    "eslint/no-template-curly-in-string": "error",
    "eslint/prefer-const": "error",
    "eslint/no-unneeded-ternary": "error",

    "oxc/branches-sharing-code": "error",

    "typescript/prefer-includes": "error",
    "typescript/prefer-nullish-coalescing": "error",
    "typescript/require-await": "error",
    "typescript/no-confusing-non-null-assertion": "error",
    "typescript/no-unnecessary-boolean-literal-compare": "error",
    "typescript/no-unnecessary-type-arguments": "error",
    "typescript/no-unnecessary-type-assertion": "error",
    "typescript/no-unnecessary-type-constraint": "error",
    "typescript/no-unnecessary-type-conversion": "error",
    "typescript/no-unnecessary-type-parameters": "error",

    "unicorn/no-negation-in-equality-check": "error",
    "unicorn/prefer-array-some": "error",
    "unicorn/prefer-at": "error",
    "unicorn/prefer-date-now": "error",
    "unicorn/prefer-import-meta-properties": "error",
    "unicorn/prefer-math-min-max": "error",
    "unicorn/prefer-regexp-test": "error",
    "unicorn/prefer-top-level-await": "error",
    "unicorn/import-style": "error",
    "unicorn/prefer-node-protocol": "error",
    "unicorn/filename-case": "error",
    "unicorn/no-useless-collection-argument": "error",
    "unicorn/prefer-default-parameters": "error",
    "unicorn/prefer-object-from-entries": "error",
    "unicorn/relative-url-style": ["error", "always"],
    "unicorn/prefer-string-slice": "error",

    "import/consistent-type-specifier-style": ["error", "prefer-top-level"],
    "import/newline-after-import": "error",

    "unicorn/no-document-cookie": "error",

    "react/exhaustive-deps": "off",
    "react/jsx-no-constructed-context-values": "off",
    "react/rules-of-hooks": "error",
    "react/jsx-key": "error",
    "react/jsx-no-duplicate-props": "error",
    "react/jsx-props-no-spread-multi": "error",
    "react/jsx-boolean-value": "error",
    "react/jsx-curly-brace-presence": "error",
    "react/jsx-handler-names": "error",

    // nursery
    "typescript/prefer-optional-chain": "error"
  },
  "options": { "typeAware": true, "typeCheck": true },
  "env": { "builtin": true },
  "ignorePatterns": ["routeTree.gen.ts", "generated/"]
}
